generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified Boolean?
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  accounts      Account[]
  pipelines     Pipeline[]
  repositories  Repository[]
  sessions      Session[]

  @@map("user")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Repository {
  id             String     @id @default(cuid())
  userId         String
  fullName       String
  provider       String
  providerRepoId String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  pipelines      Pipeline[]
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("repository")
}

model Pipeline {
  id          String         @id @default(cuid())
  repoId      String
  createdById String
  name        String
  filePath    String
  branch      String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  createdBy   User           @relation(fields: [createdById], references: [id])
  repository  Repository     @relation(fields: [repoId], references: [id], onDelete: Cascade)
  drafts      PipelineDraft?

  @@unique([repoId, filePath, branch])
  @@map("pipeline")
}

model PipelineDraft {
  id            String   @id @default(cuid())
  pipelineId    String   @unique
  configuration String
  updatedAt     DateTime @updatedAt
  pipeline      Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@map("pipeline_draft")
}

model ComponentCategory {
  id           String              @id @default(cuid())
  name         String
  slug         String              @unique
  displayOrder Int
  icon         String?
  components   PipelineComponent[]

  @@map("component_category")
}

model PipelineComponent {
  id         String            @id @default(cuid())
  categoryId String
  name       String
  type       String
  uiConfig   Json?
  syntaxes   ComponentSyntax[]
  category   ComponentCategory @relation(fields: [categoryId], references: [id])

  @@map("pipeline_component")
}

model ComponentSyntax {
  id          String            @id @default(cuid())
  componentId String
  platform    String
  template    String
  component   PipelineComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@map("component_syntax")
}

// ==========================================
// 4. ส่วน History & Rollback System
// ==========================================

model PipelineHistory {
  id            String   @id @default(cuid())
  userId        String
  provider      String   
  repoFullName  String  
  branch        String   
  filePath      String   
  commitMessage String   
  commitUrl     String?  
  actionType    String   
  yamlContent   String   @db.Text 
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pipeline_history")
}
